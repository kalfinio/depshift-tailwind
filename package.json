{
  "name": "depshift-tailwind",
  "version": "0.1.0",
  "description": "CLI and GitHub Action that scans repositories for safe Tailwind CSS v3 → v4 migration suggestions, with report, --write, --check, and --json modes.",
  "type": "module",
  "license": "MIT",
  "author": "kalfinio (https://github.com/kalfinio)",
  "homepage": "https://github.com/kalfinio/depshift-tailwind#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalfinio/depshift-tailwind.git"
  },
  "bugs": {
    "url": "https://github.com/kalfinio/depshift-tailwind/issues"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "tailwind-v4",
    "tailwindcss-v4",
    "tailwind-migration",
    "migration",
    "codemod",
    "ast",
    "ts-morph",
    "cli",
    "github-action"
  ],
  "bin": {
    "depshift-tailwind": "./dist/cli.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "prepack": "npm run build",
    "test": "vitest run",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
