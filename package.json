{
  "name": "depshift-tailwind",
  "version": "0.1.0",
  "description": "Minimal CLI that scans a local repo for safe Tailwind CSS v3 -> v4 migration issues and writes a markdown report.",
  "type": "module",
  "bin": {
    "depshift-tailwind": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "test": "vitest run",
    "dev": "tsx src/cli.ts"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "migration",
    "codemod",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
